# TarsierAlpha v2 Backend — Environment Variables

# Polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# MongoDB
MONGO_URI=mongodb://localhost:27017/tarsieralpha

# Firebase
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Agentic API
AGENT_SECRET=replace_with_strong_secret_64chars
AGENT_API_KEYS=key1,key2,key3  # comma-separated valid API keys

# Server
PORT=4000
FRONTEND_URL=https://tarsieralpha.com

# Optional: Supabase (alternative to MongoDB for real-time)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
